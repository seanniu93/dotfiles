#!/usr/bin/env bash

# Common files
export vrc="$HOME/.vimrc"

# Enable vim YouCompleteMe plugin
export VIM_ENABLE_YCM=1


#####################
# Platform Specific #
#####################

# Source platform specific configs
if [ "$IS_OSX" == 1 ]; then
    . "$HOME/.dotfiles/env_vars.macos"
elif [ "$IS_LINUX" == 1 ]; then
    . "$HOME/.dotfiles/env_vars.linux"
fi

# Source secrets if they exist
if [[ -f "$HOME/.env_vars.secret" ]]; then
    . "$HOME/.env_vars.secret"
fi
